<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Paper Plane Dodge</title>

  <style>
    body {
      margin: 0;
      overflow: hidden;
      background: #f9f3d9;
      font-family: "Hiragino Maru Gothic ProN", sans-serif;
    }

    canvas {
      display: block;
      background: linear-gradient(#bfe9ff, #f9f3d9);
      touch-action: none;
    }

    #ui {
      position: absolute;
      top: 15px;
      left: 15px;
      color: #5c6b73;
      font-size: 24px;
      font-weight: bold;
    }

    #gameOver {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      display: none;
      color: #5c6b73;
    }

    #gameOver h1 {
      font-size: 48px;
    }

    #gameOver button {
      background: #fff6c7;
      border: 2px solid #8ecae6;
      border-radius: 20px;
      padding: 12px 24px;
      font-size: 20px;
      cursor: pointer;
    }
  </style>
</head>

<body>

<div id="ui">
  Score: <span id="score">0</span>
</div>

<div id="gameOver">
  <h1>Game Over</h1>
  <p id="finalScore"></p>
  <button onclick="restartGame()">もう一回</button>
</div>

<canvas id="gameCanvas"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

let width = window.innerWidth;
let height = window.innerHeight;

canvas.width = width;
canvas.height = height;

const player = {
  x: width / 2,
  y: height - 100,
  radius: 28
};

let planes = [];
let score = 0;
let speed = 2;
let gameRunning = true;

function resize() {
  width = window.innerWidth;
  height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;
}

window.addEventListener("resize", resize);

function drawPlayer() {
  ctx.beginPath();
  ctx.fillStyle = "#fff6c7";
  ctx.arc(player.x, player.y, player.radius, 0, Math.PI * 2);
  ctx.fill();

  ctx.strokeStyle = "#8ecae6";
  ctx.lineWidth = 4;
  ctx.stroke();

  // 顔
  ctx.fillStyle = "#5c6b73";

  ctx.beginPath();
  ctx.arc(player.x - 8, player.y - 5, 3, 0, Math.PI * 2);
  ctx.arc(player.x + 8, player.y - 5, 3, 0, Math.PI * 2);
  ctx.fill();

  ctx.beginPath();
  ctx.arc(player.x, player.y + 5, 8, 0, Math.PI);
  ctx.stroke();
}

function drawPlane(plane) {
  ctx.save();

  ctx.translate(plane.x, plane.y);
  ctx.rotate(plane.rotation);

  ctx.strokeStyle = "#ffffff";
  ctx.lineWidth = 3;

  ctx.beginPath();
  ctx.moveTo(0, -20);
  ctx.lineTo(16, 20);
  ctx.lineTo(0, 10);
  ctx.lineTo(-16, 20);
  ctx.closePath();

  ctx.stroke();

  ctx.restore();
}

function spawnPlane() {
  planes.push({
    x: Math.random() * width,
    y: -30,
    rotation: Math.random() * 0.5 - 0.25
  });
}

function updatePlanes() {
  for (let i = planes.length - 1; i >= 0; i--) {

    const p = planes[i];

    p.y += speed;

    drawPlane(p);

    const dx = p.x - player.x;
    const dy = p.y - player.y;
    const distance = Math.sqrt(dx * dx + dy * dy);

    if (distance < player.radius + 18) {
      endGame();
    }

    if (p.y > height + 50) {
      planes.splice(i, 1);

      score++;
      document.getElementById("score").textContent = score;

      if (score % 5 === 0) {
        speed += 0.4;
      }
    }
  }
}

function drawBackground() {
  ctx.fillStyle = "#f9f3d9";
  ctx.fillRect(0, 0, width, height);

  for (let i = 0; i < 20; i++) {

    ctx.fillStyle = "rgba(255,255,255,0.15)";

    ctx.beginPath();

    ctx.arc(
      (i * 180 + Date.now() * 0.01) % width,
      (i * 100) % height,
      30,
      0,
      Math.PI * 2
    );

    ctx.fill();
  }
}

function gameLoop() {

  if (!gameRunning) return;

  drawBackground();

  drawPlayer();

  updatePlanes();

  requestAnimationFrame(gameLoop);
}

setInterval(() => {
  if (gameRunning) {
    spawnPlane();
  }
}, 800);

function endGame() {

  gameRunning = false;

  document.getElementById("gameOver").style.display = "block";

  document.getElementById("finalScore").textContent =
    "スコア: " + score;
}

function restartGame() {

  planes = [];
  score = 0;
  speed = 2;
  gameRunning = true;

  document.getElementById("score").textContent = "0";

  document.getElementById("gameOver").style.display = "none";

  gameLoop();
}

// スマホ操作
canvas.addEventListener("touchmove", (e) => {

  const touch = e.touches[0];

  player.x = touch.clientX;

  e.preventDefault();
});

// PC操作
canvas.addEventListener("mousemove", (e) => {
  player.x = e.clientX;
});

gameLoop();

</script>
</body>
</html>
